# Copy to .env or .env.local. The API loads .env.local first, then .env.
NODE_ENV=development

POSTGRES_USER=linkly
POSTGRES_PASSWORD=linkly_local_password
POSTGRES_DB=linkly
DATABASE_URL=postgresql://linkly:linkly_local_password@localhost:5437/linkly?schema=public

# Redis (cache + queues)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=

# Tmap Transit API
TMAP_APP_KEY=
TMAP_HTTP_TIMEOUT_MS=12000

# Cache settings
CACHE_BUCKET_MINUTES=5
CACHE_TTL_SECONDS_MIN=120
CACHE_TTL_SECONDS_MAX=300

# Chat encryption (AES-256-GCM)
# Format: version:base64Key (32 bytes). Multiple versions comma-delimited.
CHAT_ENCRYPTION_KEYS=1:BASE64_KEY
CHAT_ENCRYPTION_KEY_VERSION=1

# Chat WebSocket heartbeat
CHAT_WS_PING_INTERVAL_MS=25000
CHAT_WS_PONG_TIMEOUT_MS=60000

# CORS allowed origins (comma-separated). Empty or unset = allow all in dev, block all in prod.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Web API base URL (web dev)
NEXT_PUBLIC_API_URL=http://localhost:3001

# JWT
JWT_SECRET=CHANGE_ME_SOME_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# OAuth — Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:3001/v1/auth/kakao/callback

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/v1/auth/google/callback

# OAuth — Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:3001/v1/auth/naver/callback

# Frontend URL (for redirect after login)
FRONTEND_URL=http://localhost:3000

# API port (Nest dev default)
PORT=3001
